# ============================================================
# Muse Scoring Platform - 环境变量配置
# 使用方法: Copy-Item .env.example .env  然后编辑 .env
# ============================================================

# ──────────────────────────────────────────────
# 【必填】数据库连接
# 本地开发: 保持默认即可（Docker Compose 内部网络）
# 生产环境: 替换为 Neon/Supabase 等云数据库连接串
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/scoring

# ──────────────────────────────────────────────
# 【必填】Redis 连接
# 本地开发: 保持默认即可
# 生产环境: 替换为 Upstash 等云 Redis 连接串
# 格式: redis://[:密码@]主机:端口
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ──────────────────────────────────────────────
# 【必填·生产环境】JWT 签名密钥
# ⚠️  生产环境绝对不要使用默认值！请用下方命令生成:
# PowerShell: -join ((65..90)+(97..122)+(48..57)|Get-Random -Count 64|%{[char]$_})
# Linux/macOS: openssl rand -hex 32
# ──────────────────────────────────────────────
JWT_SECRET=<change-to-a-strong-random-secret>

# ──────────────────────────────────────────────
# 【必填】初始管理员账号
# ⚠️  首次登录后请修改默认密码！
# ──────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<change-default-password>

# ──────────────────────────────────────────────
# 【必填·生产环境】CORS 允许来源
# 本地开发: 保持 * 即可
# 生产环境: 填写你的前端域名，逗号分隔
# 示例: https://muse.yourdomain.com,https://muse-admin.yourdomain.com
# ──────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ──────────────────────────────────────────────
# 【推荐】Cloudflare Turnstile 人机验证
# 获取方式: Cloudflare Dashboard → Turnstile → Add Site
# 本地开发: 留空即跳过验证（方便调试）
# 生产环境: 必填，防止脚本批量注册
# ──────────────────────────────────────────────
TURNSTILE_SITE_KEY=<your-cloudflare-turnstile-site-key>
TURNSTILE_SECRET_KEY=<your-cloudflare-turnstile-secret-key>

# ──────────────────────────────────────────────
# 【推荐·生产环境】Cloudflare R2 图片存储
# 获取方式:
#   1. Cloudflare Dashboard → R2 → Create Bucket (命名: muse-images)
#   2. R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
#   3. 复制 Access Key ID 和 Secret Access Key
#   4. Account ID 在 Cloudflare 右侧边栏可见
# 本地开发: 留空即使用本地 images/ 目录
# 生产环境: 必填，否则图片无法正常显示
# ──────────────────────────────────────────────
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET=muse-images
# 自定义域名（可选）: https://images.yourdomain.com
# 未配置自定义域名: https://pub-{account-id}.r2.dev
R2_PUBLIC_URL=https://images.yourdomain.com
