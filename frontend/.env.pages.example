# Cloudflare Pages 环境变量模板
# 在 Cloudflare Dashboard → Pages → 你的项目 → Settings → Environment Variables 中配置

# ============================================
# 前端环境变量 (VITE_ 前缀)
# ============================================

# Turnstile Site Key (公开信息，可从 Cloudflare Turnstile Dashboard 获取)
# 格式: 0xAAAAAAAAAAAAAAAAAAAAAA
VITE_TURNSTILE_SITE_KEY=

# API 基础 URL (可选)
# 如果前后端同域部署（通过 Cloudflare Tunnel），留空即可
# 如果前后端分离部署，填写完整的后端 API 地址
# 示例: https://api.yourdomain.com
VITE_API_BASE_URL=
